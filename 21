#include<stdio.h>
int main(){
int a[]={5,10,15,20,25,30,35,40,45};
int n=9,key=20;
int l=0,r=n-1,mid,pos=-1,count=0;
while(l<=r){
mid=(l+r)/2;
count++;
if(a[mid]==key){pos=mid+1;break;}
else if(key<a[mid])r=mid-1;
else l=mid+1;
}
printf("%d\nComparisons:%d",pos,count);
return 0;
}

OUTPUT:
4
Comparisons:2
