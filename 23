#include<stdio.h>
int main(){
int points[4][2]={{1,3},{-2,2},{5,8},{0,1}};
int k=2,n=4;
int dist[4];
for(int i=0;i<n;i++)dist[i]=points[i][0]*points[i][0]+points[i][1]*points[i][1];
for(int i=0;i<n-1;i++){
for(int j=i+1;j<n;j++){
if(dist[i]>dist[j]){
int t=dist[i];dist[i]=dist[j];dist[j]=t;
int x=points[i][0],y=points[i][1];
points[i][0]=points[j][0];points[i][1]=points[j][1];
points[j][0]=x;points[j][1]=y;
}
}
}
printf("[");
for(int i=0;i<k;i++){
printf("[%d, %d]",points[i][0],points[i][1]);
if(i!=k-1)printf(", ");
}
printf("]");
return 0;
}

OUTPUT:
[[-2, 2], [0, 1]]
